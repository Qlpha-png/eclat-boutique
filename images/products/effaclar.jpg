    <script>
    
    
    
    function checkUrlAndToggleBanner() {
        var url = window.location.href;
        var bannerElement = document.querySelector('.lrpStickyBanner');
    
        console.log('Current URL:', url); // Debugging log
        console.log('Banner Element:', bannerElement); // Debugging log
    
        if (bannerElement) {
            // Check if the URL contains the target paths and doesn't include /spotscan.html
            if ((url.includes('/l-edito-peau/peau-grasse--a-tendance-acneique') || url.includes('/gammes/visage/effaclar')) && !url.endsWith('/spotscan.html') && !url.endsWith('/LRP_050.html')) {
                // Show the banner
                bannerElement.style.display = 'block';
                console.log('Banner displayed'); // Debugging log
                return true; // Indicate success
            } else {
                // Hide the banner
                bannerElement.style.display = 'none';
                console.log('Banner hidden'); // Debugging log
                return true; // Indicate success
            }
        }
        return false; // Indicate that the goal was not achieved
    }
    
    document.addEventListener('DOMContentLoaded', function () {
        // Run the function initially
        checkUrlAndToggleBanner();
    
        // Set up a 0.5-second interval to check the URL and toggle the banner
        var intervalId = setInterval(function() {
            if (checkUrlAndToggleBanner()) {
                clearInterval(intervalId);
                console.log('Interval cleared'); // Debugging log
            }
        }, 500);
    
        var closeButton = document.querySelector('.closeBanner_NEW_1');
        if (closeButton) {
            closeButton.addEventListener('click', function () {
                var banner = document.querySelector('.lrpStickyBanner');
                if (banner) {
                    banner.style.display = 'none';
                    console.log('Banner closed by user'); // Debugging log
                }
            });
        }
    });
    
    
    
    </script>
    
