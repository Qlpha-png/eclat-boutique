e/fr_FR/DSFServices-ChangePrescription&quot;,&quot;serviceCategory&quot;:&quot;diagnose&quot;,&quot;application&quot;:&quot;spotscan&quot;,&quot;customer&quot;:&quot;laroche-posay&quot;,&quot;type&quot;:&quot;std&quot;,&quot;touchpoint&quot;:&quot;web&quot;,&quot;tagName&quot;:&quot;dsf-app&quot;,&quot;switchEcom&quot;:true,&quot;displayAnalytics&quot;:null}"  data-analytics="{&quot;category&quot;:&quot;analysis::spotscan::skin&quot;,&quot;action&quot;:&quot;{{dataLayer.page.category}}::select::spotscan&quot;,&quot;label&quot;:&quot;load::spotscan&quot;,&quot;extraData&quot;:{&quot;event_name&quot;:&quot;site_load_service&quot;,&quot;service_name&quot;:&quot;spotscan&quot;,&quot;service_category&quot;:&quot;diagnose&quot;,&quot;cta_name&quot;:&quot;try myskinsos now &quot;}}" application="spotscan">Try MySkinSOS now </button> </div></div>   </div> </div>  </div> </div></div>     
