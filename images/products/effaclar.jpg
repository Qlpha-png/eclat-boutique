    .c-category-cover  .coupon-copied {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        cursor: pointer;
    }
    
    .c-category-cover  .coupon-copied.coupon-copied-visible {
        opacity: 1;
    }
    
    .c-category-cover  .coupon-code.coupon-copied-visible {
        opacity: 0;
    }

    .c-category-cover .c-content-panel__inner {
        flex-wrap: wrap;
    }

</style>
<script>
//Valtech Copy To Clipboard
    document.addEventListener("click", copyToClipboard);
    function copyToClipboard(event){
        var box = event.target;
        if(box.classList.contains("js-copy-to-clipboard")){
            var couponCodeEl = box.previousElementSibling,
                couponCode = couponCodeEl.innerText;
                
            couponCodeEl.focus();
            navigator.clipboard.writeText(couponCode); 

            box.classList.add("coupon-copied-visible"); 
            couponCodeEl.classList.add("coupon-copied-visible"); 
            setTimeout(function() { 
                box.classList.remove("coupon-copied-visible"); 
                couponCodeEl.classList.remove("coupon-copied-visible");
            }, 2000);
        }
    }
    //Copy To Clipboard END
</script>

