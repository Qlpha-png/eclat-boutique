    document.addEventListener('DOMContentLoaded', () => {
      const currentUrl = window.location.href;
      let canonicalUrl;
    
      // **EXTREMELY IMPORTANT:**  This is just a placeholder!
      // You MUST replace this with your actual category mapping logic.
      // This logic should be implemented on the server-side whenever possible.
      if (currentUrl.includes('shop-by_001_006')) {
        canonicalUrl = 'https://www.laroche-posay.fr/produits/visage/soins-anti-taches';
      } // Add more conditions for other category mappings
    
      if (canonicalUrl && !document.querySelector('link[rel="canonical"]')) {
        const canonicalTag = document.createElement('link');
        canonicalTag.rel = 'canonical';
        canonicalTag.href = canonicalUrl;
        document.head.appendChild(canonicalTag);
      }
    });
    </script>


